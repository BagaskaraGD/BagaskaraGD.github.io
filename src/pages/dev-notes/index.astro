---
import PageLayout from '../../layouts/PageLayout.astro';
import PageHero from '../../components/ui/PageHero.astro';
import { allNotes, noteCategories } from '../../data/notes';
import { profile } from '../../data/profile';

// Group notes by category
const notesByCategory = noteCategories.map((cat) => ({
  ...cat,
  notes: allNotes.filter((n) => n.categoryId === cat.id),
})).filter((c) => c.notes.length > 0);

const colorMap: Record<string, string> = {
  cyan: '', purple: 'purple', emerald: 'emerald',
  amber: 'amber', rose: 'rose', blue: 'blue',
};

let noteCounter = 0;
function nextId() {
  noteCounter++;
  return `#${String(noteCounter).padStart(3, '0')}`;
}
---

<PageLayout
  title={`Dev Notes — ${profile.name}`}
  description="Commands, patterns, and concepts I keep returning to — Git, Laravel, Docker, Flutter, MySQL, and Terminal."
>
  <PageHero
    eyebrow="// dev.notes"
    title="Commands & concepts I keep returning to"
    subtitle={`${allNotes.length} notes across ${noteCategories.length} categories.`}
  />

  <section style="padding: 0 0 96px; position:relative; z-index:1;">
    <div class="shell">

      <!-- Category filter bar -->
      <div class="filter-bar reveal">
        <button class="filter-btn active" data-filter="all">
          All Notes
          <span class="count">{allNotes.length}</span>
        </button>
        {noteCategories.map((cat) => {
          const count = allNotes.filter(n => n.categoryId === cat.id).length;
          return (
            <button class="filter-btn" data-filter={cat.id}>
              {cat.label}
              <span class="count">{count}</span>
            </button>
          );
        })}
      </div>

      <!-- Notes grouped by category -->
      {notesByCategory.map((cat) => (
        <div class="notes-category-section" data-cat-section={cat.id}>
          <div class="notes-category-header reveal">
            <div class="notes-category-icon">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <polyline points="4 17 10 11 4 5" /><line x1="12" y1="19" x2="20" y2="19" />
              </svg>
            </div>
            <h2 class="notes-category-title">{cat.label}</h2>
            <span class="notes-category-count">{cat.notes.length} notes</span>
          </div>

          <div class="notes-grid">
            {cat.notes.map((note) => {
              const colorClass = colorMap[note.color] ?? '';
              const id = nextId();
              const lines = note.command.split('\n');
              return (
                <article class="note-card reveal" data-note-cat={note.categoryId}>
                  <div class="note-head">
                    <span class={`note-cat ${colorClass}`}>
                      <span class="pill"></span>
                      {note.category}
                    </span>
                    <span class="note-id">{id}</span>
                  </div>
                  <div class="note-body">
                    <h3 class="note-title">{note.title}</h3>
                    <code class="note-cmd">
                      {lines.map((line, i) => (
                        <>
                          <span class="prompt">$</span> {line}{i < lines.length - 1 ? '\n' : ''}
                        </>
                      ))}
                    </code>
                    <p class="note-desc">{note.description}</p>
                  </div>
                  <div class="note-foot">
                    <span>{note.category.toUpperCase()}</span>
                    {note.slug && (
                      <a href={`/dev-notes/${note.slug}`}>
                        Read more
                        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                          <path d="M5 12h14" /><path d="m13 5 7 7-7 7" />
                        </svg>
                      </a>
                    )}
                  </div>
                </article>
              );
            })}
          </div>
        </div>
      ))}
    </div>
  </section>
</PageLayout>

<script>
  // Filter notes by category — shows/hides entire category sections
  const filterBtns = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
  const catSections = document.querySelectorAll<HTMLElement>('[data-cat-section]');

  filterBtns.forEach((btn) => {
    btn.addEventListener('click', () => {
      const filter = btn.dataset.filter ?? 'all';

      filterBtns.forEach((b) => b.classList.remove('active'));
      btn.classList.add('active');

      catSections.forEach((section) => {
        if (filter === 'all' || section.dataset.catSection === filter) {
          section.style.display = '';
        } else {
          section.style.display = 'none';
        }
      });
    });
  });
</script>
