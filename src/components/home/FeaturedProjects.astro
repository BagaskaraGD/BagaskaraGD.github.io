---
import { featuredProjects } from '../../data/projects';
import SectionHeader from '../ui/SectionHeader.astro';

const largeProject = featuredProjects.find((p) => p.size === 'large')!;
const smallProjects = featuredProjects.filter((p) => p.size === 'small');

const questBorderMap: Record<string, string> = {
  main: 'rgba(251,191,36,0.45)',
  side: 'rgba(167,139,250,0.45)',
  daily: 'rgba(52,211,153,0.45)',
};
const questColorMap: Record<string, string> = {
  main: 'var(--amber)',
  side: '#c4b5fd',
  daily: '#6ee7b7',
};
---

<section class="portfolio" id="portfolio">
  <div class="shell">
    <SectionHeader
      eyebrow="// featured.quests"
      title="Selected work from the journey log"
      asideText="Browse all projects →"
      asideHref="/portfolio"
    />

    <div class="portfolio-grid">
      <!-- Large featured project -->
      <a href={largeProject.link ?? '#'} class="project-card large reveal">
        <span class="quest-tag" style={`border-color: ${questBorderMap[largeProject.questType]}; color: ${questColorMap[largeProject.questType]};`}>
          {largeProject.questLabel}
        </span>
        <div class="project-thumb" style={largeProject.thumbBg ? `background: ${largeProject.thumbBg}` : ''}>
          <svg viewBox="0 0 600 380" preserveAspectRatio="xMidYMid slice" aria-hidden="true">
            <defs>
              <linearGradient id="g1" x1="0" x2="1" y1="0" y2="1">
                <stop offset="0%" stop-color="#22d3ee" stop-opacity="0.35" />
                <stop offset="100%" stop-color="#a78bfa" stop-opacity="0.15" />
              </linearGradient>
            </defs>
            <rect width="600" height="380" fill="url(#g1)" />
            <rect x="40" y="40" width="520" height="60" rx="10" fill="#0a1124" stroke="#1f2a4a" />
            <rect x="56" y="58" width="120" height="10" rx="3" fill="#22d3ee" opacity="0.8" />
            <rect x="56" y="76" width="200" height="8" rx="3" fill="#9fb0c9" opacity="0.5" />
            <circle cx="530" cy="70" r="14" fill="#22d3ee" opacity="0.8" />
            <rect x="40" y="120" width="160" height="160" rx="10" fill="#0a1124" stroke="#1f2a4a" />
            <rect x="56" y="138" width="80" height="8" rx="3" fill="#9fb0c9" opacity="0.5" />
            <rect x="56" y="160" width="128" height="24" rx="4" fill="#22d3ee" opacity="0.9" />
            <rect x="56" y="200" width="100" height="6" rx="3" fill="#3a4a78" />
            <rect x="56" y="216" width="120" height="6" rx="3" fill="#3a4a78" />
            <rect x="56" y="232" width="80" height="6" rx="3" fill="#3a4a78" />
            <rect x="56" y="252" width="60" height="14" rx="4" fill="#a78bfa" opacity="0.7" />
            <rect x="220" y="120" width="340" height="160" rx="10" fill="#0a1124" stroke="#1f2a4a" />
            <polyline points="240,250 280,210 320,225 360,180 400,200 440,150 480,170 520,130 540,150" fill="none" stroke="#22d3ee" stroke-width="2.5" />
            <polyline points="240,250 280,210 320,225 360,180 400,200 440,150 480,170 520,130 540,150 540,260 240,260" fill="#22d3ee" opacity="0.15" />
            <rect x="40" y="300" width="520" height="50" rx="10" fill="#0a1124" stroke="#1f2a4a" />
            <rect x="56" y="316" width="60" height="18" rx="4" fill="#34d399" opacity="0.8" />
            <rect x="126" y="316" width="80" height="18" rx="4" fill="#1f2a4a" />
            <rect x="216" y="316" width="100" height="18" rx="4" fill="#1f2a4a" />
          </svg>
        </div>
        <div class="project-body">
          <div class="project-meta">
            <span>{largeProject.year}</span>
            <span class="dot"></span>
            <span>{largeProject.category}</span>
            <span class="dot"></span>
            <span>Client Work</span>
          </div>
          <h3 class="project-title">{largeProject.title}</h3>
          <p class="project-desc">{largeProject.description}</p>
          <div class="project-foot">
            <div class="project-tags">
              {largeProject.tags.map((tag) => (
                <span class={`tag ${tag.color && tag.color !== 'cyan' ? tag.color : ''}`}>
                  <span class="swatch"></span>{tag.name}
                </span>
              ))}
            </div>
            <span class="project-link">
              View case study
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M7 17 17 7" /><path d="M7 7h10v10" />
              </svg>
            </span>
          </div>
        </div>
      </a>

      <!-- Small projects stack -->
      <div class="project-stack">
        {smallProjects.map((project) => (
          <a href={project.link ?? '#'} class="project-card small reveal">
            <span
              class="quest-tag"
              style={`border-color: ${questBorderMap[project.questType]}; color: ${questColorMap[project.questType]};`}
            >
              {project.questLabel}
            </span>
            <div class="project-thumb" style={project.thumbBg ? `background: ${project.thumbBg}` : ''}>
              <svg viewBox="0 0 600 300" preserveAspectRatio="xMidYMid slice" aria-hidden="true">
                <rect width="600" height="300" fill="transparent" />
                <rect x="180" y="20" width="240" height="260" rx="18" fill="#0a1124" stroke="#1f2a4a" stroke-opacity="0.6" />
                <rect x="196" y="44" width="208" height="212" rx="10" fill="#101a36" />
                <rect x="210" y="60" width="120" height="10" rx="3" fill={project.questType === 'side' ? '#a78bfa' : '#34d399'} opacity="0.85" />
                <rect x="210" y="82" width="180" height="8" rx="3" fill="#3a4a78" />
                <rect x="210" y="104" width="180" height="44" rx="8" fill="#0a1124" stroke="#1f2a4a" />
                <rect x="222" y="116" width="32" height="20" rx="4" fill={project.questType === 'side' ? '#a78bfa' : '#34d399'} opacity="0.8" />
                <rect x="262" y="118" width="80" height="8" rx="3" fill="#9fb0c9" opacity="0.6" />
                <rect x="262" y="130" width="60" height="6" rx="3" fill="#3a4a78" />
                <rect x="210" y="162" width="180" height="44" rx="8" fill="#0a1124" stroke="#1f2a4a" />
                <rect x="222" y="174" width="32" height="20" rx="4" fill="#22d3ee" opacity="0.75" />
                <rect x="262" y="176" width="80" height="8" rx="3" fill="#9fb0c9" opacity="0.6" />
                <rect x="262" y="188" width="60" height="6" rx="3" fill="#3a4a78" />
                <rect x="210" y="218" width="180" height="28" rx="6" fill="#101a36" stroke="#1f2a4a" />
                <rect x="222" y="226" width="60" height="12" rx="3" fill="#22d3ee" opacity="0.6" />
              </svg>
            </div>
            <div class="project-body">
              <div class="project-meta">
                <span>{project.year}</span>
                <span class="dot"></span>
                <span>{project.category}</span>
              </div>
              <h3 class="project-title">{project.title}</h3>
              <p class="project-desc">{project.description}</p>
              <div class="project-foot">
                <div class="project-tags">
                  {project.tags.map((tag) => (
                    <span class={`tag ${tag.color && tag.color !== 'cyan' ? tag.color : ''}`}>
                      <span class="swatch"></span>{tag.name}
                    </span>
                  ))}
                </div>
                <span class="project-link">
                  Details
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M7 17 17 7" /><path d="M7 7h10v10" />
                  </svg>
                </span>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </div>
</section>
