---
import { profile } from '../../data/profile';
---

<section class="contact" id="contact">
  <div class="shell">
    <div class="contact-panel reveal">
      <div class="contact-grid">
        <!-- Left: CTA copy -->
        <div>
          <p class="contact-eyebrow">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.36 12.1 19.79 19.79 0 0 1 1.27 3.44C1.27 2.2 2.12 1.15 3.37 1h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.37a16 16 0 0 0 6 6l.83-.83a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92Z" />
            </svg>
            // start.a.quest
          </p>
          <h2>Have a project in mind?<br /><span class="accent">Let's build it.</span></h2>
          <p>
            Whether it's a full Laravel system, a landing page, or a bug that won't die —
            I'm available for freelance work and collaborations. Reach out and let's talk.
          </p>
          <div class="contact-actions">
            <a
              href={`mailto:${profile.contact.email}`}
              class="btn btn-primary btn-lg"
            >
              Send an Email
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M5 12h14" /><path d="m13 5 7 7-7 7" />
              </svg>
            </a>
            <a href={`https://${profile.contact.whatsapp}`} target="_blank" rel="noopener" class="btn btn-ghost btn-lg">
              WhatsApp
            </a>
          </div>
        </div>

        <!-- Right: contact list -->
        <div class="contact-list">
          <a href={`mailto:${profile.contact.email}`} class="contact-row">
            <span class="ico">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <rect width="20" height="16" x="2" y="4" rx="2" /><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7" />
              </svg>
            </span>
            <div>
              <div class="label">Email</div>
              <div class="value">{profile.contact.email}</div>
            </div>
            <span class="go" aria-hidden="true">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M7 17 17 7" /><path d="M7 7h10v10" />
              </svg>
            </span>
          </a>

          <a href={`https://${profile.contact.github}`} target="_blank" rel="noopener" class="contact-row purple">
            <span class="ico">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0 1 12 6.844a9.59 9.59 0 0 1 2.504.337c1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.02 10.02 0 0 0 22 12.017C22 6.484 17.522 2 12 2Z" />
              </svg>
            </span>
            <div>
              <div class="label">GitHub</div>
              <div class="value">{profile.contact.github}</div>
            </div>
            <span class="go" aria-hidden="true">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M7 17 17 7" /><path d="M7 7h10v10" />
              </svg>
            </span>
          </a>

          <a href={`https://${profile.contact.linkedin}`} target="_blank" rel="noopener" class="contact-row emerald">
            <span class="ico">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z" /><rect width="4" height="12" x="2" y="9" /><circle cx="4" cy="4" r="2" />
              </svg>
            </span>
            <div>
              <div class="label">LinkedIn</div>
              <div class="value">{profile.contact.linkedin}</div>
            </div>
            <span class="go" aria-hidden="true">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M7 17 17 7" /><path d="M7 7h10v10" />
              </svg>
            </span>
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
