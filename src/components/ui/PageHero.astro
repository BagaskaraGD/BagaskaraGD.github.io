---
interface Props {
  eyebrow: string;
  title: string;
  subtitle?: string;
  align?: 'left' | 'center';
}
const { eyebrow, title, subtitle, align = 'left' } = Astro.props;
const centered = align === 'center';
---

<section class="page-hero">
  <div class={`shell ${centered ? 'page-hero--center' : ''}`}>
    <div class="page-hero-inner reveal">
      <span class="page-hero-eyebrow">{eyebrow}</span>
      <h1 class="page-hero-title">{title}</h1>
      {subtitle && <p class="page-hero-subtitle">{subtitle}</p>}
    </div>
    <div class="page-hero-divider reveal"></div>
  </div>
</section>
